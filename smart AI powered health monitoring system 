        cout << "1. Water Tracker\n";
        cout << "2. Sleep Tracker\n";
        cout << "3. Medicine Reminder\n";
        cout << "4. Symptom Checker\n";
        cout << "5. Health Dashboard\n";
        cout << "6. AI Chatbot\n";
        cout << "7. AI Health Tips\n";
        cout << "8. Health Risk System\n";
        cout << "9. Daily Health Report\n";
        cout << "10. Save User History\n";
        cout << "11. Exit\n";

        cout << "\nEnter your choice: ";
        cin >> choice;

        switch(choice) {

            case 1:
                waterTracker();
                break;

            case 2:
                sleepTracker();
                break;

            case 3:
                medicineReminder();
                break;

            case 4:
                symptomChecker();
                break;

            case 5:
                healthDashboard();
                break;

            case 6:
                aiChatbot();
                break;

            case 7:
                aiHealthTips();
                break;

            case 8:
                healthRiskSystem();
                break;

            case 9:
